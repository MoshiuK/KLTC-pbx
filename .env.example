# =============================================================================
# WhiteLabel PBX - Environment Configuration
# =============================================================================
# Copy this to .env and fill in your actual values

# Server
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# =============================================================================
# Database — Neon Serverless PostgreSQL
# Get your connection strings from https://console.neon.tech
# =============================================================================
# Pooled connection (for the app — uses Neon's connection pooler)
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-YOUR-ENDPOINT.us-east-2.aws.neon.tech/whitelabel_pbx?sslmode=require"
# Direct connection (for Prisma migrations only)
DIRECT_DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-YOUR-ENDPOINT.us-east-2.aws.neon.tech/whitelabel_pbx?sslmode=require"

# =============================================================================
# SignalWire — Get these from your SignalWire dashboard
# https://your-space.signalwire.com/credentials
# =============================================================================
SIGNALWIRE_PROJECT_ID=your-project-id-here
SIGNALWIRE_API_TOKEN=your-api-token-here
SIGNALWIRE_SPACE_URL=your-space.signalwire.com

# Webhook Base URL — must be publicly reachable by SignalWire
# For local dev: ngrok http 3000 → use the https URL
# For production: your actual domain
WEBHOOK_BASE_URL=https://your-domain.com/api/webhooks/signalwire

# =============================================================================
# JWT Authentication
# =============================================================================
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# Platform Admin — first admin account created by seed script
# =============================================================================
PLATFORM_ADMIN_EMAIL=admin@yourplatform.com
PLATFORM_ADMIN_PASSWORD=change-this-password

# =============================================================================
# S3 Storage (Optional — for recordings, voicemail, branding assets)
# Works with AWS S3, DigitalOcean Spaces, Backblaze B2, MinIO
# If not configured, files are stored locally in ./storage
# =============================================================================
# S3_BUCKET=your-bucket-name
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# S3_ENDPOINT=https://nyc3.digitaloceanspaces.com  # Only for non-AWS S3
# S3_CDN_URL=https://your-cdn.example.com          # Optional CDN URL

# File Storage (local fallback when S3 is not configured)
STORAGE_PATH=./storage

# Logging
LOG_LEVEL=info
