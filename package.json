{
  "name": "whitelabel-pbx",
  "version": "1.0.0",
  "description": "Whitelabel PBX system powered by SignalWire",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "cd client && npm run dev",
    "start": "node server/index.js",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "node server/db/seed.js",
    "db:studio": "npx prisma studio",
    "build:client": "cd client && npm run build",
    "test": "jest --coverage",
    "lint": "eslint server/ --ext .js"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "@signalwire/realtime-api": "^3.12.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "express-validator": "^7.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prisma": "^5.10.0",
    "eslint": "^8.56.0",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
